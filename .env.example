# Environment selection
# - dev     -> Ollama (default)
# - staging -> Groq
# - prod    -> OpenAI
APP_ENV=dev
# Optional override: ollama|groq|openai
# LLM_PROVIDER=ollama

# Database
# Local dev (host) example:
# DATABASE_URL=postgresql+psycopg://chatbot:chatbot@localhost:5432/chatbot
# Container (compose) example:
DATABASE_URL=postgresql+psycopg://chatbot:chatbot@postgres:5432/chatbot
DB_INIT_MAX_WAIT_SECONDS=10
# Auto-apply alembic migrations at app startup (default: true in dev/staging, false in prod)
# AUTO_APPLY_MIGRATIONS=true
# Seed demo catalog at app startup (default: true in dev/staging, false in prod)
# SEED_DEMO_DATA=true

# Ollama (OpenAI-compatible API)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
# Optional for hosted/private gateways; local Ollama normally works without real key.
OLLAMA_API_KEY=ollama

# Groq (OpenAI-compatible API)
GROQ_API_KEY=your_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4.1-mini

# API security (optional; if set, requests to /v1/* require x-api-key except /v1/health)
# API_KEY=change_me

# CORS (optional; comma-separated origins. Example: https://app.example.com,http://localhost:3000)
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Runtime
# WEB_CONCURRENCY=2
